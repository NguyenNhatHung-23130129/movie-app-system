<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <!-- ExoPlayer View -->
    <com.google.android.exoplayer2.ui.StyledPlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:use_controller="true"
        app:player_layout_resource="@layout/exo_styled_player_layout" />

    <!-- Thông tin phim và điều khiển -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1a1a1a">

        <!-- Tên phim -->
        <TextView
            android:id="@+id/tv_movie_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên Phim"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Tập và thời lượng -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_current_episode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tập 1"
                android:textSize="14sp"
                android:textColor="@android:color/lighter_gray" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="14sp"
                android:textColor="@android:color/lighter_gray" />
        </LinearLayout>

        <!-- Nút điều khiển -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:spacing="16dp">

            <ImageButton
                android:id="@+id/btn_prev_episode"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_prev_episode"
                android:contentDescription="Tập trước"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/white"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_playlist"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_playlist"
                android:contentDescription="Danh sách tập"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/white"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_next_episode"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_next_episode"
                android:contentDescription="Tập tiếp theo"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/white"/>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>