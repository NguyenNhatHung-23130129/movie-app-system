<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1115">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Quay lại" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Trợ giúp &amp; Hỗ trợ"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CÂU HỎI THƯỜNG GẶP"
                android:textColor="#5A6175"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1D24"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2C313C"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:text="Làm thế nào để đổi mật khẩu?"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="Vào Cài đặt > Tài khoản &amp; Bảo mật > Đổi mật khẩu để thay đổi mật khẩu của bạn."
                        android:textColor="#9EA3B0"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2C313C"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:text="Phim bị lỗi không tải được?"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="Hãy kiểm tra kết nối mạng hoặc xóa cache trong phần cài đặt ứng dụng."
                        android:textColor="#9EA3B0"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIÊN HỆ HỖ TRỢ"
                android:textColor="#5A6175"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnContactEmail"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                app:cardBackgroundColor="#1A1D24"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2C313C"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp">
                    <TextView
                        android:text="Gửi Email cho chúng tôi"
                        android:layout_centerVertical="true"
                        android:textColor="#FFFFFF"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:text="support@movieapp.com"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:textColor="#FF3B30"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>