<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111317">

    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:background="#111317"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/img_header_logo"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/movie_24"
            app:tint="#FFB4AA" />

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Quản lý Phim"
            android:textColor="#FFFEFD"
            android:textSize="20sp"
            android:textStyle="bold" />


        <ImageView
            android:id="@+id/img_header_profile"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/outline_account_circle_24" />
    </LinearLayout>

    <include
        android:id="@+id/layout_bottom_navigation"
        layout="@layout/layout_admin_bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_header"
        android:layout_above="@id/layout_bottom_navigation"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:orientation="vertical">

            <EditText
                android:id="@+id/edt_search_movie"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginVertical="16dp"
                android:background="@drawable/bg_search_bar"
                android:drawableStart="@drawable/search_24"
                android:drawablePadding="12dp"
                android:hint="Tìm kiếm phim theo tên..."
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="#FFFFFF"
                app:tint="#FFFFFF"
                android:textColorHint="#4B5563"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_filter_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_filter_active"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="20dp"
                    android:layout_marginEnd="8dp"
                    android:textColor="#FFF7F6"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Tất cả" />

                <TextView
                    android:id="@+id/btn_filter_published"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_filter_inactive"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="20dp"
                    android:layout_marginEnd="8dp"
                    android:textColor="#E9BCB6"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Đã xuất bản" />

                <TextView
                    android:id="@+id/btn_filter_draft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_filter_inactive"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="20dp"
                    android:textColor="#E9BCB6"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Bản nháp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcv_movie_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_movie_card" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ImageButton
        android:id="@+id/fab_rating"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_above="@id/layout_bottom_navigation"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:padding="16dp"
        android:src="@drawable/ic_plus"
        android:background="@drawable/bg_filter_active"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Rating Button" />

</RelativeLayout>