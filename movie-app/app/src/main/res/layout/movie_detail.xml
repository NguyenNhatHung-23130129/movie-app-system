<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111317"
    android:fitsSystemWindows="true">

    <ScrollView
        android:id="@+id/scrollViewContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:fitsSystemWindows="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/includeFooter">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="420dp">

                <ImageView
                    android:id="@+id/imgDetailPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/movie_24" tools:ignore="ContentDescription" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@drawable/bg_gradient_detail"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MỚI"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="#E50914"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:layout_marginEnd="12dp"/>

                        <RatingBar
                            style="?android:attr/ratingBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:rating="4.5"
                            android:progressTint="#F59E0B"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvDetailRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4.5"
                            android:textColor="#E2E2E8"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDetailTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chiến Binh Ánh Sáng:\nKhởi Đầu"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvDetailSubInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="2024  •  Hành động, Viễn tưởng"
                        android:textColor="#8E8E93"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvDetailTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- phút  •  4K Ultra HD"
                        android:textColor="#8E8E93"
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:id="@+id/btnWatchNow"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_red"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_play"
                        app:tint="#FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem Ngay"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent"/>

                <FrameLayout
                    android:id="@+id/btnAddToMyList"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_btn_dark_square"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_add"
                        app:tint="#E2E2E8"/>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/tabDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="24dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvTabDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mô tả"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <View
                        android:id="@+id/viewDescLine"
                        android:layout_width="24dp"
                        android:layout_height="2dp"
                        android:background="#E50914"
                        android:layout_marginTop="6dp"
                        android:visibility="visible"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabComments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="24dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvTabComments"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bình luận"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <View
                        android:id="@+id/viewCommentLine"
                        android:layout_width="24dp"
                        android:layout_height="2dp"
                        android:background="#E50914"
                        android:layout_marginTop="6dp"
                        android:visibility="invisible"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabRelated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvTabRelated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Liên quan"
                        android:textColor="#8E8E93"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <View
                        android:id="@+id/viewRelatedLine"
                        android:layout_width="24dp"
                        android:layout_height="2dp"
                        android:background="#E50914"
                        android:layout_marginTop="6dp"
                        android:visibility="invisible"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTabDescriptionContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:paddingHorizontal="16dp"
                    android:text="Đang tải dữ liệu nội dung..."
                    android:textColor="#E2E2E8"
                    android:textSize="15sp"
                    android:lineSpacingExtra="5dp"
                    android:layout_marginBottom="24dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2"
                    android:paddingHorizontal="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:background="@drawable/bg_info_card"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đạo diễn"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvDetailDirector"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="20dp"
                            android:text="Đang cập nhật"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:background="@drawable/bg_info_card"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diễn viên"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvDetailActor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="20dp"
                            android:text="Đang cập nhật"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:background="@drawable/bg_info_card"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quốc gia"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvDetailCountry"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="20dp"
                            android:text="Đang cập nhật"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:background="@drawable/bg_info_card"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:layout_marginStart="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Trạng thái"
                            android:textColor="#8E8E93"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvDetailStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="20dp"
                            android:text="Đang cập nhật"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"
                            android:maxLines="1"
                            android:ellipsize="end"/>
                    </LinearLayout>
                </GridLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTabCommentsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_info_card"
                    android:padding="12dp"
                    android:layout_marginBottom="24dp">

                    <RatingBar
                        android:id="@+id/ratingBarInput"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:stepSize="1.0"
                        android:rating="5"
                        android:progressTint="#F59E0B"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/edtCommentInput"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Viết bình luận của bạn..."
                            android:textColorHint="#8E8E93"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:inputType="text"/>

                        <ImageView
                            android:id="@+id/btnSendComment"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_menu_send"
                            android:padding="8dp"
                            app:tint="#E50914"
                            android:layout_marginStart="8dp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Người dùng ẩn danh • Vừa xong"
                        android:textColor="#8E8E93"
                        android:textSize="12sp"/>

                    <RatingBar
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:rating="5"
                        android:isIndicator="true"
                        android:progressTint="#F59E0B"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phim đỉnh thực sự, kỹ xảo mãn nhãn quá mọi người ơi!"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Minh Tuấn • 2 giờ trước"
                        android:textColor="#8E8E93"
                        android:textSize="12sp"/>

                    <RatingBar
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:rating="4"
                        android:isIndicator="true"
                        android:progressTint="#F59E0B"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mong chờ phần tiếp theo ra mắt sớm, kết phim mở quá."
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"/>
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutTabRelatedContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nội dung cùng thể loại đề xuất:"
                    android:textColor="#8E8E93"
                    android:textSize="14sp"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRelatedMovies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:scrollbars="none"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnDetailBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_circle_action"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            tools:ignore="ContentDescription"
            app:tint="#FFFFFF"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnDetailShare"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_action"
                android:padding="8dp"
                android:src="@drawable/ic_chat"
                android:layout_marginEnd="12dp"
                tools:ignore="ContentDescription"
                app:tint="#FFFFFF"/>

            <ImageView
                android:id="@+id/btnDetailHeart"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_action"
                android:padding="8dp"
                android:src="@drawable/ic_favorite"
                tools:ignore="ContentDescription"
                app:tint="#FFFFFF"/>
        </LinearLayout>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>