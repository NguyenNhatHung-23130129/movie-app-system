<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1115"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- PROFILE HEADER BLOCK -->
        <LinearLayout
            android:id="@+id/layoutAvatarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/sym_def_app_icon"
                    app:shapeAppearanceOverlay="@style/CircleImageView"
                    app:strokeColor="#FF1E27"
                    app:strokeWidth="2dp" />

                <!-- Tích vàng nhỏ góc dưới bên phải Avatar -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignEnd="@id/imgAvatar"
                    android:layout_alignBottom="@id/imgAvatar"
                    android:layout_marginEnd="2dp"
                    android:layout_marginBottom="2dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#FFCC00" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nguyễn Văn A"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="vana.nguyen@email.com"
                android:textColor="#9EA3B0"
                android:textSize="14sp" />

            <!-- HỘI VIÊN PREMIUM BADGE -->
            <TextView
                android:id="@+id/badgePremium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@android:drawable/toast_frame"
                android:backgroundTint="#FFCC00"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:text="🎖️ HỘI VIÊN PREMIUM"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- STATS LAYOUT (Hàng Thống Kê Chỉ Số) -->
        <LinearLayout
            android:id="@+id/layoutStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layoutAvatarContainer">

            <!-- Phim đã xem -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1A1D24"
                android:padding="12dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="124"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHIM ĐÃ XEM"
                    android:textColor="#5A6175"
                    android:textSize="9sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Giờ xem (Nổi bật) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#221518"
                android:padding="12dp"
                android:layout_marginHorizontal="3dp"
                style="@style/Widget.MaterialComponents.CardView">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="482"
                    android:textColor="#FF3B30"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GIỜ XEM"
                    android:textColor="#FF3B30"
                    android:textSize="9sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Danh sách -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#1A1D24"
                android:padding="12dp"
                android:layout_marginStart="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DANH SÁCH"
                    android:textColor="#5A6175"
                    android:textSize="9sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- CARD 1: CÁC HOẠT ĐỘNG DỊCH VỤ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardServiceActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#1A1D24"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2C313C"
            app:layout_constraintTop_toBottomOf="@id/layoutStats">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Quản lý gói cước -->
                <RelativeLayout
                    android:id="@+id/btnManagePackage"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/ic_package"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_slideshow"
                        app:tint="#FF4D4D" />
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_package"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quản lý gói cước"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gói hiện tại: 4K Ultra HD"
                            android:textColor="#FFB4AA"
                            android:textSize="12sp" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="❯"
                        android:textColor="#5A6175" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2C313C"/>

                <!-- Danh sách của tôi (Thay thế mục Phim yêu thích) -->
                <RelativeLayout
                    android:id="@+id/btnFavoriteMovies"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/ic_mylist"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/btn_star_big_off"
                        app:tint="#9EA3B0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_mylist"
                        android:layout_marginStart="16dp"
                        android:text="Danh sách của tôi"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="❯"
                        android:textColor="#5A6175" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2C313C"/>

                <!-- Lịch sử giao dịch (Thay thế mục Đổi mật khẩu) -->
                <RelativeLayout
                    android:id="@+id/btnChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/ic_history"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="#9EA3B0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_history"
                        android:layout_marginStart="16dp"
                        android:text="Lịch sử giao dịch"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="❯"
                        android:textColor="#5A6175" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 2: CÀI ĐẶT VÀ TRỢ GIÚP -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSystemActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#1A1D24"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2C313C"
            app:layout_constraintTop_toBottomOf="@id/cardServiceActions">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Cài đặt (Thay thế mục Cài đặt thông báo cũ) -->
                <RelativeLayout
                    android:id="@+id/btnNotificationSettings"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/ic_settings"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_preferences"
                        app:tint="#9EA3B0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_settings"
                        android:layout_marginStart="16dp"
                        android:text="Cài đặt"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="❯"
                        android:textColor="#5A6175" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#2C313C"/>

                <!-- Trợ giúp & Hỗ trợ (Nút mới ánh xạ vào ID Chỉnh sửa hồ sơ cũ) -->
                <RelativeLayout
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="?attr/selectableItemBackground"
                    android:paddingHorizontal="16dp">
                    <ImageView
                        android:id="@+id/ic_help"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_help"
                        app:tint="#9EA3B0" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/ic_help"
                        android:layout_marginStart="16dp"
                        android:text="Trợ giúp &amp; Hỗ trợ"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="❯"
                        android:textColor="#5A6175" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 3: ĐĂNG XUẤT -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1A1D24"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#2C313C"
            app:layout_constraintTop_toBottomOf="@id/cardSystemActions"
            app:layout_constraintBottom_toTopOf="@id/txtFooter">

            <RelativeLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="16dp">
                <ImageView
                    android:id="@+id/ic_Logout"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:tint="#FF3B30" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/ic_Logout"
                    android:layout_marginStart="16dp"
                    android:text="Đăng xuất"
                    android:textColor="#FF3B30"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- FOOTER INFO -->
        <TextView
            android:id="@+id/txtFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MovieFlow v2.4.0 • Made with ❤️"
            android:textColor="#4E5566"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/cardLogout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>