<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1115"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/icGuestAvatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:background="#1A1D24"
            android:padding="20dp"
            app:tint="#5A6175"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvGuestTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bạn chưa đăng nhập"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvGuestSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="Hãy đăng nhập tài khoản MovieFlow để lưu lại những bộ phim yêu thích và đồng bộ lịch sử xem phim của bạn."
            android:textColor="#9EA3B0"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnGoToLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@android:color/holo_red_dark"
            android:text="ĐĂNG NHẬP NGAY"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <TextView
        android:id="@+id/txtGuestFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MovieFlow v2.4.0 • Made with ❤️"
        android:textColor="#4E5566"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>